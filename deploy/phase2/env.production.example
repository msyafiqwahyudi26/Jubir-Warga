# Phase 2 production env vars — TEMPLATE
# Copy to apps/web/.env.production.local on the VPS, fill values, chmod 600.
# DO NOT commit the filled file. Real values live ONLY on VPS + GitHub secrets.

# === Supabase ====================================================
# Public URL — safe to expose
NEXT_PUBLIC_SUPABASE_URL=https://ifrautpvbhdbhieystxk.supabase.co

# Anon key — public (RLS gates access). Get from:
# https://supabase.com/dashboard/project/ifrautpvbhdbhieystxk/settings/api
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role — SERVER ONLY. Bypasses RLS. Never expose to client bundle.
SUPABASE_SERVICE_ROLE_KEY=

# === App =========================================================
NEXT_PUBLIC_APP_URL=https://jubirbetaapp.spdindonesia.org
NEXT_PUBLIC_APP_ENV=production

# === Sentry — error tracking =====================================
# Public DSN — safe to expose. Format: https://<key>@oXXXX.ingest.sentry.io/<project-id>
# Get from Sentry → Project Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=

# Server-side org auth token for source map upload via CI.
# Get from Sentry → Settings → Auth Tokens (org-level, scope: project:write).
# NEVER expose. Set as GitHub secret SENTRY_AUTH_TOKEN, not in this file.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=spd-indonesia
SENTRY_PROJECT=jubir-warga-web

# === Plausible — privacy-first analytics =========================
# Domain harus match yang di-add di Plausible dashboard (case-sensitive).
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=jubirbetaapp.spdindonesia.org

# === Node ========================================================
NODE_ENV=production
PORT=3001
