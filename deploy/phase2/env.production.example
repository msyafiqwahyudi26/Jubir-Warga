# Phase 2 production env vars — TEMPLATE
# Copy to apps/web/.env.production.local on the VPS, fill values, chmod 600.
# DO NOT commit the filled file. Real values live ONLY on VPS + GitHub secrets.

# === Supabase ====================================================
# Public URL — safe to expose
NEXT_PUBLIC_SUPABASE_URL=https://ifrautpvbhdbhieystxk.supabase.co

# Anon key — public (RLS gates access). Get from:
# https://supabase.com/dashboard/project/ifrautpvbhdbhieystxk/settings/api
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role — SERVER ONLY. Bypasses RLS. Never expose to client bundle.
SUPABASE_SERVICE_ROLE_KEY=

# === App =========================================================
NEXT_PUBLIC_APP_URL=https://jubirbetaapp.spdindonesia.org
NEXT_PUBLIC_APP_ENV=production

# === Error tracking — GlitchTip self-host (Sentry-compatible) ====
# Per Spec #38: pivot dari Sentry SaaS ke GlitchTip self-host (VPS, $0 cost).
# Self-host: https://glitchtip.spdindonesia.org (lihat deploy/self-host/README.md)
# DSN format: https://<key>@glitchtip.spdindonesia.org/<project-id>
# Get DSN from: glitchtip.spdindonesia.org → project Settings → Client Keys
NEXT_PUBLIC_SENTRY_DSN=

# Server-side auth token untuk source map upload via CI.
# Get from: glitchtip.spdindonesia.org → user menu → API Tokens (scope: project:write)
# NEVER expose. Set as GitHub secret SENTRY_AUTH_TOKEN, not in this file.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=spd-indonesia
SENTRY_PROJECT=jubir-warga-web

# === Analytics — Umami self-host (Plausible alternative) =========
# Per Spec #38: pivot dari Plausible SaaS ke Umami self-host (VPS, $0 cost).
# Self-host: https://umami.spdindonesia.org
#
# NOTE: existing apps/web/src/components/plausible-script.tsx hardcoded ke
# plausible.io. Script swap = follow-up Window D / separate spec. Sampai swap
# landed, leave NEXT_PUBLIC_PLAUSIBLE_DOMAIN kosong; Umami vars siap di-pakai
# setelah script swap.
NEXT_PUBLIC_UMAMI_DOMAIN=umami.spdindonesia.org
NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# === LEGACY: Plausible (deprecated post script-swap) =============
# Kosongkan untuk no-op. Set kalau masih butuh Plausible SaaS sementara.
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# === Node ========================================================
NODE_ENV=production
PORT=3001
