# GlitchTip self-host — environment variables (TEMPLATE)
# Copy ke /opt/glitchtip/.env, fill values, chmod 600.
# Generate SECRET_KEY: python3 -c 'import secrets; print(secrets.token_urlsafe(50))'
# Generate POSTGRES_PASSWORD: openssl rand -base64 32

# === Postgres ====================================================
POSTGRES_USER=glitchtip
POSTGRES_PASSWORD=
POSTGRES_DB=glitchtip

# === Django/Celery ===============================================
# 50+ char random string. NEVER commit. NEVER reuse across env.
SECRET_KEY=

# === Email — error notification ==================================
# Pattern: smtp://user:pass@host:port[?options]
# Default consolemail:// = log to docker logs (no real email).
# Production: pakai SMTP relay (Mailgun, Postmark, SES) atau Hostinger SMTP.
# Contoh: smtp://noreply%40spdindonesia.org:PASS@smtp.hostinger.com:587?tls=True
EMAIL_URL=consolemail://
DEFAULT_FROM_EMAIL=noreply@spdindonesia.org

# === Signup gate =================================================
# Env var name per GlitchTip docs: ENABLE_OPEN_USER_REGISTRATION
# False = signup ditutup setelah admin pertama dibuat (Title Case Python boolean)
# Set True sementara saat first-run untuk createsuperuser, lalu False + restart
ENABLE_OPEN_USER_REGISTRATION=False
