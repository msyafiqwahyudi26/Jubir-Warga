# Umami self-host — environment variables (TEMPLATE)
# Copy ke /opt/umami/.env, fill values, chmod 600.
# Generate APP_SECRET: openssl rand -base64 32
# Generate HASH_SALT: openssl rand -base64 32
# Generate POSTGRES_PASSWORD: openssl rand -base64 32

# === Postgres ====================================================
POSTGRES_USER=umami
POSTGRES_PASSWORD=
POSTGRES_DB=umami

# === Umami app ===================================================
# 32+ byte random string. JWT signing + cookie encryption.
APP_SECRET=

# 32+ byte random string. PII (visitor IP) hashing salt.
# WAJIB unique per deployment — kalau bocor, IP bisa di-deanonimize via rainbow table.
HASH_SALT=
