# === Error tracking — GlitchTip self-host (Sentry-compatible) ==
# Per Spec #38 Sprint 4: pivot dari Sentry SaaS ke GlitchTip self-host VPS
# karena $0 budget tambahan. @sentry/nextjs SDK kompatibel — drop-in.
#
# Production self-host: https://glitchtip.spdindonesia.org
# DSN format: https://<key>@glitchtip.spdindonesia.org/<project_id>
# Get DSN from: glitchtip.spdindonesia.org → project → Settings → Client Keys
#
# Local dev: kosongkan supaya SDK no-op. Atau pakai sandbox project di GlitchTip.
# NEXT_PUBLIC_SENTRY_DSN=https://example@glitchtip.spdindonesia.org/1
#
# Server-side auth token untuk source map upload via CI. Jangan commit.
# Get from: glitchtip.spdindonesia.org → user menu → API Tokens
# SENTRY_AUTH_TOKEN=
SENTRY_ORG=spd-indonesia
SENTRY_PROJECT=jubir-warga-web

# === Analytics — Umami self-host (Plausible alternative) ========
# Per Spec #38 Sprint 4: pivot dari Plausible SaaS ke Umami self-host VPS.
# Production self-host: https://umami.spdindonesia.org
#
# NOTE: Existing apps/web/src/components/plausible-script.tsx (per Spec #18)
# masih hardcoded ke plausible.io — Window D / follow-up swap perlu untuk
# enable Umami tracking. Variable di bawah disiapkan duluan.
#
# NEXT_PUBLIC_UMAMI_DOMAIN=umami.spdindonesia.org
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=<uuid-dari-umami-dashboard>

# === LEGACY: Plausible (deprecated, akan di-swap ke Umami) ======
# Kalau kosong, PlausibleScript component no-op (aman buat local dev).
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=jubirbetaapp.spdindonesia.org
