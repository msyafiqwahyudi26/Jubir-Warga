                <button className="text-xs mt-2 underline" style={{ color: CK.coral }}>Baca lengkap →</button>
              </div>

              <div className="p-4 rounded-2xl border" style={{ borderColor: CK.line, background:'#fff' }}>
                <h4 className="font-bold text-sm mb-3" style={{ color: CK.blue }}>Mod Online</h4>
                <div className="space-y-1.5">
                  {[
                    { name: 'Erik Kurniawan', online: true },
                    { name: 'Sari Lestari',   online: true },
                    { name: 'Bilal Sukarno',  online: false },
                  ].map((m,i) => (
                    <div key={i} className="flex items-center gap-2 text-xs">
                      <span className="w-2 h-2 rounded-full" style={{ background: m.online ? CK.mint : CK.ink+'33' }}></span>
                      <span style={{ color: CK.ink+'BB' }}>{m.name}</span>
                    </div>
                  ))}
                </div>
              </div>
            </aside>
          </div>
        )}

        {/* ── CHAPTER ── */}
        {tab === 'chapter' && (
          <div className="py-8">
            <div className="grid md:grid-cols-3 gap-4">
              {CHAPTERS.map((c, i) => (
                <div key={i}
                  className={`p-5 rounded-2xl border ${c.active ? 'card-lift cursor-pointer' : 'opacity-55'}`}
                  style={{ borderColor: c.active ? CK.line : CK.line+'80', background: c.active ? '#fff' : CK.line+'44' }}>
                  <div className="flex items-start justify-between mb-3">
                    <h3 className="font-display text-xl font-bold" style={{ color: CK.blue }}>{c.name}</h3>
                    <KPill color={c.active ? 'mint' : 'grey'}>{c.active ? 'Aktif' : 'Segera'}</KPill>
                  </div>
                  {c.active && (
                    <p className="text-sm mb-2" style={{ color: CK.ink + '80' }}>
                      <span className="font-bold" style={{ color: CK.blue }}>{c.members}</span> anggota
                    </p>
                  )}
                  <p className="text-xs mb-5" style={{ color: CK.ink + '66' }}>📅 {c.event}</p>
                  {c.active
                    ? <KBtn variant="outline" size="sm">Gabung →</KBtn>
                    : <KBtn variant="outline-light" size="sm" disabled>Daftar antrean</KBtn>
                  }
                </div>
              ))}
            </div>
          </div>
        )}

        {/* ── SUB-KOMUNITAS (BARU) ── */}
        {tab === 'subkom' && (
          <div className="py-8">
            <div className="flex items-center justify-between mb-5 flex-wrap gap-3">
              <div>
                <h3 className="font-display text-2xl font-bold" style={{ color: CK.blue }}>Sub-komunitas</h3>
                <p className="text-sm mt-1" style={{ color: CK.ink+'88' }}>Versi private dari topik untuk yang serius. Diskusi lebih fokus, mod ketat.</p>
              </div>
              <KBtn variant="outline" size="sm">+ Usul sub-komunitas baru</KBtn>
            </div>
            <div className="grid md:grid-cols-2 gap-4">
              {SUB_KOMUNITAS.map((s, i) => (
                <div key={i} className="p-5 rounded-2xl border card-lift" style={{ borderColor: CK.line, background:'#fff' }}>
                  <div className="flex items-start justify-between mb-2">
                    <h4 className="font-display font-bold text-lg" style={{ color: CK.blue }}>{s.name}</h4>
                    <KPill color={s.apply==='open' ? 'mint' : 'marigold'}>
                      {s.apply==='open' ? 'Buka' : 'Apply'}
                    </KPill>
                  </div>
                  <p className="text-sm mb-4" style={{ color: CK.ink+'AA' }}>{s.desc}</p>
                  <div className="flex items-center justify-between text-xs" style={{ color: CK.ink+'77' }}>
                    <span><strong>{s.anggota}</strong> anggota · Mod: <strong>{s.mod}</strong></span>
                    <button className="font-bold" style={{ color: CK.coral }}>
                      {s.apply==='open' ? 'Gabung →' : 'Apply gabung →'}
                    </button>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}

        {/* ── EVENT ── */}
        {tab === 'event' && (
          <div className="py-8">
            <div className="grid md:grid-cols-3 gap-4">
              {EVENTS.map((e, i) => (
                <div key={i} className="rounded-2xl border overflow-hidden card-lift cursor-pointer" style={{ borderColor: CK.line }}>
                  <div className="h-36 flex flex-col items-center justify-center gap-2"
                    style={{ background: `hsl(${i*60+200},18%,90%)` }}>
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke={CK.blue} strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round" opacity="0.55">
                      <rect x="3" y="4" width="18" height="18" rx="2"/>
                      <line x1="16" y1="2" x2="16" y2="6"/>
                      <line x1="8" y1="2" x2="8" y2="6"/>
                      <line x1="3" y1="10" x2="21" y2="10"/>
                    </svg>
                  </div>
                  <div className="p-4 bg-white">
                    <KPill color={typeColor[e.type]||'blue'} className="mb-2">{e.type}</KPill>
                    <h4 className="font-display font-semibold text-sm leading-snug mb-2 clamp2" style={{ color: CK.ink }}>
                      {e.title}
                    </h4>
                    <p className="text-xs mb-4" style={{ color: CK.ink + '66' }}>📅 {e.date} &nbsp;·&nbsp; 📍 {e.loc}</p>
                    <KBtn variant="coral" size="sm">RSVP →</KBtn>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}

        {/* ── DIREKTORI ── */}
        {tab === 'direktori' && (
          <div className="py-8">
            <div className="grid grid-cols-2 md:grid-cols-4 gap-4">
              {MITRA.map((m, i) => (
                <div key={i}
                  className="p-5 rounded-2xl border flex items-center justify-center card-lift cursor-pointer min-h-20"
                  style={{ borderColor: CK.line, background: '#fff' }}>
                  <span className="font-semibold text-sm" style={{ color: CK.blue }}>{m}</span>
                </div>
              ))}
            </div>
          </div>
        )}
      </div>

      {/* FAB */}
      <button
        onClick={() => setNewDiscOpen(true)}
        className="fixed bottom-20 md:bottom-6 right-6 w-14 h-14 rounded-full shadow-xl flex items-center justify-center text-2xl z-30 transition-transform hover:scale-105 active:scale-95"
        style={{ background: CK.coral, color: '#fff' }}
      >+</button>

      {/* New Discussion Modal */}
      <KModal open={newDiscOpen} onClose={() => setNewDiscOpen(false)}>
        <div className="p-6">
          <h3 className="font-display text-xl font-bold mb-1" style={{ color: CK.blue }}>Mulai Diskusi Baru</h3>
          <p className="text-sm mb-4" style={{ color: CK.ink + '77' }}>
            Sampaikan pikiran, pertanyaan, atau cerita kamu ke komunitas.
          </p>
          <input
            value={discTitle}
            onChange={e => setDiscTitle(e.target.value)}
            placeholder="Judul diskusi kamu..."
            className="w-full px-4 py-3 rounded-xl border mb-3 text-sm outline-none"
            style={{ borderColor: discTitle ? CK.blue : CK.line }}
          />
          <textarea
            value={discBody}
            onChange={e => setDiscBody(e.target.value)}
            placeholder="Ceritakan lebih lanjut..."
            rows={4}
            className="w-full px-4 py-3 rounded-xl border mb-4 text-sm outline-none resize-none"
            style={{ borderColor: discBody ? CK.blue : CK.line }}
          />
          <div className="flex justify-end gap-2">
            <KBtn variant="ghost" onClick={() => setNewDiscOpen(false)}>Batal</KBtn>
            <KBtn variant="coral" disabled={!discTitle} onClick={() => setNewDiscOpen(false)}>
              Post Diskusi
            </KBtn>
          </div>
        </div>
      </KModal>
    </div>
  );
}

Object.assign(window, { PageKomunitas });
