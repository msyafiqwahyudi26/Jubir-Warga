// ── Vote Arrow ──
function VoteCol({ up, down }) {
  const [vote, setVote] = useKomState(0); // -1 down, 0 none, 1 up
  const score = up - down + vote;
  return (
    <div className="flex flex-col items-center gap-0.5 flex-shrink-0" style={{ width: 36 }}>
      <button
        onClick={() => setVote(vote === 1 ? 0 : 1)}
        className="w-7 h-7 rounded-md flex items-center justify-center transition-all"
        style={{
          background: vote === 1 ? CK.coral + '22' : 'transparent',
          color:      vote === 1 ? CK.coral : CK.ink + '77',
        }}
        aria-label="Upvote"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill={vote === 1 ? 'currentColor' : 'none'} stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
          <polygon points="12 2 19 21 12 17 5 21 12 2" />
        </svg>
      </button>
      <span className="font-mono text-xs font-bold" style={{ color: vote !== 0 ? CK.coral : CK.blue }}>{score}</span>
      <button
        onClick={() => setVote(vote === -1 ? 0 : -1)}
        className="w-7 h-7 rounded-md flex items-center justify-center transition-all"
        style={{
          background: vote === -1 ? CK.blue + '22' : 'transparent',
          color:      vote === -1 ? CK.blue_soft || CK.blue : CK.ink + '77',
        }}
        aria-label="Downvote"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill={vote === -1 ? 'currentColor' : 'none'} stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" style={{ transform: 'rotate(180deg)' }}>
          <polygon points="12 2 19 21 12 17 5 21 12 2" />
        </svg>
      </button>
    </div>
  );
}

function PageKomunitas({ onNavigate }) {
  const [tab,         setTab]         = useKomState('forum');
  const [filterCat,   setFilterCat]   = useKomState('semua');
  const [filterLoc,   setFilterLoc]   = useKomState('semua');
  const [filterFmt,   setFilterFmt]   = useKomState('semua');
  const [sort,        setSort]        = useKomState('panas');
  const [topikOpen,   setTopikOpen]   = useKomState(true);
  const [lokasiOpen,  setLokasiOpen]  = useKomState(true);
  const [fmtOpen,     setFmtOpen]     = useKomState(false);
  const [newDiscOpen, setNewDiscOpen] = useKomState(false);
  const [discTitle,   setDiscTitle]   = useKomState('');
  const [discBody,    setDiscBody]    = useKomState('');

  const TAB_ITEMS = [
    {id:'forum',     label:'Forum'},
    {id:'chapter',   label:'Chapter Regional'},
    {id:'subkom',    label:'Sub-komunitas'},
    {id:'event',     label:'Event'},
    {id:'direktori', label:'Direktori Mitra'},
  ];

  const typeColor = { Hybrid:'marigold', Offline:'coral', Online:'mint' };

  // Filter threads
  const filteredThreads = THREADS.filter((t) =>
    (filterCat === 'semua' || t.cat === filterCat) &&
    (filterLoc === 'semua' || t.loc === filterLoc) &&
    (filterFmt === 'semua' || t.fmt === filterFmt)
  );

  const Caret = ({ open }) => (
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" style={{ transform: open ? 'rotate(0deg)' : 'rotate(-90deg)', transition: 'transform 0.15s' }}>
      <polyline points="6 9 12 15 18 9" />
    </svg>
  );

  return (
    <div>
      {/* Hero */}
      <section className="py-12 border-b" style={{ borderColor: CK.line }}>
        <div className="max-w-6xl mx-auto px-6 flex items-start justify-between gap-4 flex-wrap">
          <div>
            <h1 className="font-display font-bold text-4xl md:text-5xl leading-tight" style={{ color: CK.blue }}>
              Komunitas
            </h1>
            <p className="mt-3 text-lg max-w-xl" style={{ color: CK.ink + '88' }}>
              Tempat warga ngumpul, ngobrol, berbagi cerita, dan saling belajar.
            </p>
          </div>
          <KBtn variant="coral" size="lg" onClick={() => setNewDiscOpen(true)}>
            + Mulai Diskusi Baru
          </KBtn>
        </div>
      </section>

      <div className="max-w-6xl mx-auto px-6">
        <KTabs items={TAB_ITEMS} active={tab} onChange={setTab} />

        {/* ── FORUM (REDESIGN) ── */}
        {tab === 'forum' && (
          <div className="py-8 flex flex-col md:flex-row gap-6 items-start">
            {/* Left sidebar — 3-tier kategori */}
            <aside className="hidden md:flex flex-col gap-1 w-56 flex-shrink-0">
              {/* Semua */}
              <button
                onClick={() => { setFilterCat('semua'); setFilterLoc('semua'); setFilterFmt('semua'); }}
                className="text-left px-3 py-2 rounded-lg text-sm font-bold transition-all mb-3"
                style={{
                  background: (filterCat==='semua' && filterLoc==='semua' && filterFmt==='semua') ? CK.blue : 'transparent',
                  color:      (filterCat==='semua' && filterLoc==='semua' && filterFmt==='semua') ? CK.cream : CK.ink,
                }}
              >Semua thread</button>

              {/* TOPIK UTAMA */}
              <button
                onClick={() => setTopikOpen(!topikOpen)}
                className="flex items-center justify-between text-xs uppercase tracking-wider font-bold px-2 py-1.5 rounded"
                style={{ color: CK.ink + '66' }}
              >
                <span>Topik Utama</span>
                <Caret open={topikOpen} />
              </button>
              {topikOpen && (
                <div className="ml-1 mb-3">
                  {TOPIK_UTAMA.map(t => (
                    <button
                      key={t.id}
                      onClick={() => setFilterCat(filterCat === t.id ? 'semua' : t.id)}
