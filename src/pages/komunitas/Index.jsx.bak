                  <span className="text-xs font-bold" style={{ color: CK.ink+'77' }}>Filter aktif:</span>
                  {filterCat!=='semua' && <KPill color="blue">{TOPIK_UTAMA.find(x=>x.id===filterCat)?.label} ✕</KPill>}
                  {filterLoc!=='semua' && <KPill color="coral">{LOKASI.find(x=>x.id===filterLoc)?.label} ✕</KPill>}
                  {filterFmt!=='semua' && <KPill color="mint">{FORMAT.find(x=>x.id===filterFmt)?.label} ✕</KPill>}
                  <button
