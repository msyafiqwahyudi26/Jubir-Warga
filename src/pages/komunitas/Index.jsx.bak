                  >
                    {/* Vote column */}
                    <VoteCol up={t.upvotes} down={t.downvotes} />

                    {/* Content */}
                    <div className="flex-1 min-w-0">
                      <div className="flex items-center gap-2 mb-1.5 flex-wrap">
