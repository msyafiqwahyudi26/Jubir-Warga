              {filteredThreads.length === 0 && (
                <div className="text-center py-12 rounded-2xl border" style={{ borderColor: CK.line, background: '#fff' }}>
                  <p className="font-display text-xl mb-2" style={{ color: CK.blue }}>Belum ada thread di filter ini.</p>
                  <p className="text-sm" style={{ color: CK.ink+'77' }}>Coba filter lain, atau mulai diskusi sendiri.</p>
                </div>
              )}

              <div className="space-y-3">
                {filteredThreads.map(t => (
                  <article
                    key={t.id}
                    className="p-4 rounded-2xl border card-lift cursor-pointer flex gap-3"
